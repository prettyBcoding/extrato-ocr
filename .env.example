# ── Mistral AI ──────────────────────────────────
# Obter em: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here


# ── Google Sheets ────────────────────────────────
# ID da sua spreadsheet (está no URL: /spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Nome do separador/aba onde os dados serão inseridos
SHEET_NAME=Extratos

# Credenciais da Service Account do Google (JSON completo numa só linha)
# Ver README para instruções de como obter
GOOGLE_CREDENTIALS_JSON=COLA_AQUI_O_JSON_DA_SERVICE_ACCOUNT